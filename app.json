{
  "expo": {
    "name": "Nekomews",
    "slug": "nekomews",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "nekomews",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFFBF5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "jp.nekomews.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "プロフィール写真や日記の写真を撮影するために使用します。",
        "NSPhotoLibraryUsageDescription": "プロフィール写真や日記の写真を選択するために使用します。",
        "NSLocationWhenInUseUsageDescription": "近くのシッターを検索するために使用します。"
      }
    },
    "android": {
      "package": "jp.nekomews.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
