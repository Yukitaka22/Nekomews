{
  "expo": {
    "name": "Nekomews",
    "slug": "nekomews",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nekomews",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFBF5"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "jp.nekomews.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "プロフィール写真や日記の写真を撮影するために使用します。",
        "NSPhotoLibraryUsageDescription": "プロフィール写真や日記の写真を選択するために使用します。",
        "NSLocationWhenInUseUsageDescription": "近くのシッターを検索するために使用します。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFBF5"
      },
      "package": "jp.nekomews.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#F59E0B"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/NotoSansJP-Regular.ttf",
            "./assets/fonts/NotoSansJP-Medium.ttf",
            "./assets/fonts/NotoSansJP-Bold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "owner": "REPLACE_WITH_EAS_USERNAME"
  }
}
