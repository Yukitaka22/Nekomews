# ===== Supabase =====
# Supabase プロジェクトダッシュボード → Settings → API から取得
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===== Stripe =====
# Stripe Dashboard → Developers → API keys から取得
# 公開可能キー (publishable) のみ。秘密鍵はクライアントに入れない
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# ===== Sentry =====
# Sentry.io → Settings → Projects → nekomews から DSN を取得
EXPO_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/xxxxxxx

# ===== PostHog =====
# app.posthog.com → Project Settings から取得
EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxxxxxxxxxxxx
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ===== 環境識別子 =====
# development / staging / production
EXPO_PUBLIC_ENV=development

# ===== サーバーサイド（Edge Functions） =====
# 以下はクライアントに入れてはいけない。supabase secrets で管理
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
